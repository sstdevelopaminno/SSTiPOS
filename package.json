{
  "name": "pos-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "corepack pnpm --filter backoffice-web build && corepack pnpm --filter qr-login-web build",
    "build:turbo": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "corepack pnpm -r --if-present test"
  },
  "devDependencies": {
    "playwright": "1.55.0",
    "turbo": "^2.0.12",
    "typescript": "^5.8.3"
  }
}
