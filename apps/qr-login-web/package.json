    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@opennextjs/cloudflare": "^1.8.2",
    "eslint": "^9.24.0",
    "eslint-config-next": "^16.2.5",
    "typescript": "^5.8.3",
    "wrangler": "^4.19.1"
